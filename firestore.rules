rules_version = '2';

// Firestore Security Rules для TodoApp
// Разворачиваются через Firebase Console → Firestore → Rules
// или через Firebase CLI: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Все операции только для аутентифицированных пользователей (включая анонимных)
    // Firebase Auth Anonymous Sign-In включается в Firebase Console → Authentication → Sign-in methods

    match /users/{userId} {

      // Пользователь видит и изменяет только своих данные
      // request.auth.uid == userId гарантирует изоляцию между пользователями

      match /tasks/{taskId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;

        // Валидация при создании/обновлении задачи
        allow create, update: if request.auth != null
                              && request.auth.uid == userId
                              && request.resource.data.title is string
                              && request.resource.data.title.size() > 0
                              && request.resource.data.title.size() <= 500
                              && request.resource.data.isCompleted is bool
                              && request.resource.data.isImportant is bool;

        match /subtasks/{subtaskId} {
          allow read, write: if request.auth != null
                             && request.auth.uid == userId;

          allow create, update: if request.auth != null
                                && request.auth.uid == userId
                                && request.resource.data.title is string
                                && request.resource.data.title.size() > 0;
        }
      }
    }
  }
}
